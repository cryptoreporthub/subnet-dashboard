# Environment variables example
PORT=5000
DEBUG=True

# --- Phase B1: live on-chain subnet feed (internal.chain_client / internal.live_subnets) ---
# Blockmachine public Bittensor JSON-RPC endpoint (override to any Substrate/Bittensor RPC)
BLOCKMACHINE_RPC_URL=https://rpc.blockmachine.io
BLOCKMACHINE_RPC_TIMEOUT_SECONDS=10
BLOCKMACHINE_RPC_RETRIES=3
# How often the background feed re-syncs from chain (seconds)
LIVE_SUBNETS_SYNC_INTERVAL_SECONDS=300
# Max age before the feed is reported stale (seconds)
LIVE_SUBNETS_MAX_STALE_SECONDS=1800
# Hard cap on a single chain sync (seconds)
LIVE_SUBNETS_SYNC_TIMEOUT_SECONDS=60
# Set to false to disable the background chain sync (falls back to TaoMarketCap/registry)
LIVE_SUBNETS_AUTO_SYNC=true
